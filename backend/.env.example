# Gemini API — required. Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash-lite

# Database
DATABASE_URL=sqlite:///./skillquest.db

# Comma-separated list of origins allowed to call this API with credentials
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Where the /ai/* endpoints live. Defaults to this same server (self-contained
# mode). Point this at http://localhost:8001 to use the standalone AI service
# in services/ instead — see services/README.md.
AI_SERVICE_URL=http://localhost:8000

# Game config
DEFAULT_DOMAIN=Data Structures & Algorithms

# RL difficulty tuner (epsilon-greedy bandit)
RL_HARD_THRESHOLD=0.80
RL_MEDIUM_THRESHOLD=0.50
RL_EPSILON=0.1
