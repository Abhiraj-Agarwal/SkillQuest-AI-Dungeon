# LLM Provider
LLM_PROVIDER=google
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.0-flash

# Database
DATABASE_URL=sqlite:///./skillquest.db

# Browser and optional standalone AI service
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AI_SERVICE_URL=http://localhost:8000

# Game config
DEFAULT_DOMAIN=Data Structures & Algorithms
MAX_HINT_TOKENS=3
STREAK_RESET_HOUR=0

# NLP judge thresholds
JUDGE_CORRECT_THRESHOLD=0.65
JUDGE_PARTIAL_THRESHOLD=0.30
JUDGE_FALLBACK_RANGE_LOW=0.55
JUDGE_FALLBACK_RANGE_HIGH=0.70

# RL tuner
RL_HARD_THRESHOLD=0.80
RL_MEDIUM_THRESHOLD=0.50
RL_EPSILON=0.1

# Mock toggle
USE_MOCK_AI=true
