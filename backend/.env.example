# Gemini API — required. Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# gemini-2.5-flash-lite (and gemini-2.0-flash) are no longer available to new
# API keys as of this project's build -- verified directly against the
# Gemini API; gemini-flash-lite-latest is the confirmed-working equivalent.
LLM_MODEL=gemini-flash-lite-latest

# Database
DATABASE_URL=sqlite:///./skillquest.db

# Comma-separated list of origins allowed to call this API with credentials.
# :3001 is included because `next dev` silently falls back to it whenever
# :3000 is still occupied by a stale dev server from a previous run.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Where the /ai/* endpoints live. Defaults to this same server (self-contained
# mode). Point this at http://localhost:8001 to use the standalone AI service
# in services/ instead — see services/README.md.
AI_SERVICE_URL=http://localhost:8000

# Game config
DEFAULT_DOMAIN=Data Structures & Algorithms

# RL difficulty tuner (epsilon-greedy bandit)
RL_HARD_THRESHOLD=0.80
RL_MEDIUM_THRESHOLD=0.50
RL_EPSILON=0.1
