# LLM provider config -- Gemini only, get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Update this to whatever Gemini model name is current for your account/quota.
LLM_MODEL=gemini-flash-lite-latest

# Game config
DEFAULT_DOMAIN=Data Structures & Algorithms

# NLP judge thresholds
JUDGE_CORRECT_THRESHOLD=0.65
JUDGE_PARTIAL_THRESHOLD=0.30
# Used when Gemini is unavailable for borderline-answer adjudication.
JUDGE_LOCAL_CORRECT_THRESHOLD=0.50
# Widened from the README's literal 0.55-0.70 after validating against the
# real all-MiniLM-L6-v2 model: true paraphrases and subtly-wrong answers on
# DSA topics measured as low as 0.52 and as high as 0.83 cosine similarity,
# outside that narrower band. 0.45-0.85 catches those without touching the
# 0.65/0.30 correct/partial cutoffs below.
JUDGE_FALLBACK_RANGE_LOW=0.45
JUDGE_FALLBACK_RANGE_HIGH=0.85

# RL tuner
RL_HARD_THRESHOLD=0.80
RL_MEDIUM_THRESHOLD=0.50
RL_EPSILON=0.1
